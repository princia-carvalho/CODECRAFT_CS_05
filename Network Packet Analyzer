import tkinter as tk
from tkinter import ttk
from scapy.all import sniff, IP, TCP, UDP, Raw
import threading

running = False

def process_packet(packet):
    if packet.haslayer(IP):
        ip = packet[IP]
        src = ip.src
        dst = ip.dst
        proto = ""

        info = ""

        if packet.haslayer(TCP):
            proto = "TCP"
            info = f"{packet[TCP].sport} -> {packet[TCP].dport}"
        elif packet.haslayer(UDP):
            proto = "UDP"
            info = f"{packet[UDP].sport} -> {packet[UDP].dport}"
        else:
            proto = str(ip.proto)

        if packet.haslayer(Raw):
            payload = packet[Raw].load[:30]
            info += f" | {payload}"

        # Insert into table
        tree.insert("", tk.END, values=(src, dst, proto, info))


def sniff_packets():
    global running
    sniff(prn=process_packet, store=False, stop_filter=lambda x: not running)


def start_sniffing():
    global running
    running = True
    thread = threading.Thread(target=sniff_packets)
    thread.daemon = True
    thread.start()


def stop_sniffing():
    global running
    running = False


# ---------------- GUI ----------------
root = tk.Tk()
root.title("Mini Packet Sniffer (Wireshark-like)")
root.geometry("800x400")

frame = tk.Frame(root)
frame.pack(fill=tk.BOTH, expand=True)

columns = ("Source IP", "Destination IP", "Protocol", "Info")

tree = ttk.Treeview(frame, columns=columns, show="headings")

for col in columns:
    tree.heading(col, text=col)
    tree.column(col, width=150)

tree.pack(fill=tk.BOTH, expand=True)

# Scrollbar
scrollbar = ttk.Scrollbar(tree, orient="vertical", command=tree.yview)
tree.configure(yscroll=scrollbar.set)
scrollbar.pack(side="right", fill="y")

# Buttons
btn_frame = tk.Frame(root)
btn_frame.pack(fill=tk.X)

start_btn = tk.Button(btn_frame, text="Start Sniffing", command=start_sniffing, bg="green", fg="white")
start_btn.pack(side=tk.LEFT, padx=10, pady=5)

stop_btn = tk.Button(btn_frame, text="Stop Sniffing", command=stop_sniffing, bg="red", fg="white")
stop_btn.pack(side=tk.LEFT, padx=10, pady=5)

root.mainloop()
